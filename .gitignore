# ============================================================
# WordPress - chỉ track custom theme (ludoa) và custom plugins
# ============================================================

# === CRITICAL: WordPress config (chứa DB credentials, secret keys) ===
wp-config.php

# === Uploads (media files - binary, không thuộc git) ===
wp-content/uploads/

# === WordPress core mặc định - không phải custom ===
wp-content/themes/twenty*/

# === WordPress temp / cache ===
# wp-content/upgrade/
# wp-content/cache/
# wp-content/backup*/
# wp-content/advanced-cache.php
# wp-content/wp-cache-config.php
# wp-content/object-cache.php

# === Xserver specific ===
.htaccess
php.ini
.user.ini

# === Environment & secrets ===
.env
.env.*
!.env.example

# === OS / IDE ===
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# === Logs ===
*.log
error_log
debug.log
wp-content/debug.log
memo.md
